# Runtime
BOT_MODE=testnet
BASE_SYMBOL=BTC/USDT
TIMEFRAME=1m
LOOP_INTERVAL_SEC=300

# Strategy / risk
CONFIDENCE_FLOOR=0.72
RISK_PER_TRADE=0.005
DAILY_MAX_LOSS=0.02
MAX_CONCURRENT_POSITIONS=1
COOLDOWN_MIN=10
MAX_SPREAD_BPS=8
MAX_FEE_BPS=12

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Exchange
BYBIT_API_KEY=
BYBIT_API_SECRET=
BYBIT_TESTNET=true
USE_LIVE_MARKET_DATA=false

# CoinGecko optional
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3

# Telegram Bot API
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS=123456789
TELEGRAM_POLL_TIMEOUT_SEC=5
